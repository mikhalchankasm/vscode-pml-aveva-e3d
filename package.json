{
  "name": "pml-aveva-e3d",
  "displayName": "PML for AVEVA E3D",
  "description": "Language support for PML (Programmable Macro Language) AVEVA E3D with full LSP and IntelliSense",
  "version": "0.13.1",
  "publisher": "mikhalchankasm",
  "author": {
    "name": "MIKHALCHANKA SIARHEI"
  },
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=20.19.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Snippets"
  ],
  "keywords": [
    "pml",
    "aveva",
    "e3d",
    "pdms",
    "macro"
  ],
  "galleryBanner": {
    "color": "#1f4f7a",
    "theme": "dark"
  },
  "qna": "marketplace",
  "main": "./out/extension.js",
  "icon": "./icons/pml-icon.png",
  "contributes": {
    "keybindings": [
      {
        "command": "pml.showStringMethods",
        "key": "ctrl+shift+s",
        "when": "editorTextFocus && resourceExtname == '.pml'"
      },
      {
        "command": "pml.showRealMethods",
        "key": "ctrl+shift+r",
        "when": "editorTextFocus && resourceExtname == '.pml'"
      },
      {
        "command": "pml.showArrayMethods",
        "key": "ctrl+shift+a",
        "when": "editorTextFocus && resourceExtname == '.pml'"
      },
      {
        "command": "pml.showDbrefMethods",
        "key": "ctrl+shift+d",
        "when": "editorTextFocus && resourceExtname == '.pml'"
      },
      {
        "command": "pml.showAllMethods",
        "key": "ctrl+shift+m",
        "when": "editorTextFocus && resourceExtname == '.pml'"
      }
    ],
    "languages": [
      {
        "id": "pml",
        "aliases": [
          "PML",
          "pml",
          "Programmable Macro Language"
        ],
        "extensions": [
          ".pml",
          ".pmlobj",
          ".pmlfnc",
          ".pmlfrm",
          ".pmlmac",
          ".pmlcmd"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/pml-icon.png",
          "dark": "./icons/pml-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "pml",
        "scopeName": "source.pml",
        "path": "./syntaxes/pml.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "pml",
        "path": "./snippets/pml.json"
      }
    ],
    "commands": [
      {
        "command": "pml.quickActions.open",
        "title": "Quick Actions and Presets...",
        "category": "PML",
        "icon": "$(zap)"
      },
      {
        "command": "pml.toggleVariableTypeHints",
        "title": "Toggle Variable Type Hints",
        "category": "PML",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "pml.agentKit.reviewCurrentFile",
        "title": "Review Current File",
        "category": "PML",
        "icon": "$(checklist)"
      },
      {
        "command": "pml.agentKit.explainCurrentFinding",
        "title": "Explain Current Finding",
        "category": "PML",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "pml.agentKit.openHelpForFinding",
        "title": "Open Help For Finding",
        "category": "PML",
        "icon": "$(book)"
      },
      {
        "command": "pml.agentKit.checkHealth",
        "title": "Check Agent Kit Health",
        "category": "PML",
        "icon": "$(pulse)"
      },
      {
        "command": "pml.agentKit.checkLiveE3dAvoxStatus",
        "title": "Check Live E3D/Avox Status",
        "category": "PML",
        "icon": "$(radio-tower)"
      },
      {
        "command": "pml.formatDocument",
        "title": "Format PML Document",
        "category": "PML"
      },
      {
        "command": "pml.sortMethodsAscending",
        "title": "Sort Methods (A→Z)",
        "category": "PML"
      },
      {
        "command": "pml.sortMethodsDescending",
        "title": "Sort Methods (Z→A)",
        "category": "PML"
      },
      {
        "command": "pml.sortLinesAsc",
        "title": "Sort Lines A-Z",
        "category": "PML Tools",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "pml.sortLinesDesc",
        "title": "Sort Lines Z-A",
        "category": "PML Tools",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "pml.sortLinesLength",
        "title": "Sort Lines by Length",
        "category": "PML Tools",
        "icon": "$(text-size)"
      },
      {
        "command": "pml.sortLinesSmart",
        "title": "Smart Natural Sort",
        "category": "PML Tools",
        "icon": "$(symbol-numeric)"
      },
      {
        "command": "pml.removeDuplicates",
        "title": "Remove Duplicate Lines",
        "category": "PML Tools",
        "icon": "$(chrome-minimize)"
      },
      {
        "command": "pml.removeConsecutiveDuplicates",
        "title": "Remove Consecutive Duplicates",
        "category": "PML Tools",
        "icon": "$(exclude)"
      },
      {
        "command": "pml.removeEmptyLines",
        "title": "Remove Empty Lines",
        "category": "PML Tools",
        "icon": "$(dash)"
      },
      {
        "command": "pml.removeWhitespaceLines",
        "title": "Remove Whitespace-Only Lines",
        "category": "PML Tools",
        "icon": "$(whitespace)"
      },
      {
        "command": "pml.trimWhitespace",
        "title": "Trim Trailing Whitespace",
        "category": "PML Tools",
        "icon": "$(remove)"
      },
      {
        "command": "pml.tabsToSpaces",
        "title": "Convert Tabs to Spaces",
        "category": "PML Tools",
        "icon": "$(arrow-right)"
      },
      {
        "command": "pml.spacesToTabs",
        "title": "Convert Spaces to Tabs",
        "category": "PML Tools",
        "icon": "$(arrow-left)"
      },
      {
        "command": "pml.extractVariables",
        "title": "Extract Variables",
        "category": "PML Tools",
        "icon": "$(symbol-variable)"
      },
      {
        "command": "pml.extractMethods",
        "title": "Extract Methods",
        "category": "PML Tools",
        "icon": "$(symbol-method)"
      },
      {
        "command": "pml.addComments",
        "title": "Add Comments",
        "category": "PML Tools",
        "icon": "$(comment)"
      },
      {
        "command": "pml.removeComments",
        "title": "Remove Comments",
        "category": "PML Tools",
        "icon": "$(comment-unresolved)"
      },
      {
        "command": "pml.prints.next",
        "title": "Next $P Print",
        "category": "PML Prints",
        "icon": "$(arrow-down)"
      },
      {
        "command": "pml.prints.previous",
        "title": "Previous $P Print",
        "category": "PML Prints",
        "icon": "$(arrow-up)"
      },
      {
        "command": "pml.prints.actions",
        "title": "$P Print Actions",
        "category": "PML Prints",
        "icon": "$(output)"
      },
      {
        "command": "pml.prints.clear",
        "title": "$P Print Actions (Legacy Alias)",
        "category": "PML Prints",
        "icon": "$(output)"
      },
      {
        "command": "pml.prints.commentAll",
        "title": "Comment All $P Prints",
        "category": "PML Prints",
        "icon": "$(comment)"
      },
      {
        "command": "pml.prints.uncommentAll",
        "title": "Uncomment All $P Prints",
        "category": "PML Prints",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "pml.prints.deleteAll",
        "title": "Delete All $P Prints",
        "category": "PML Prints",
        "icon": "$(trash)"
      },
      {
        "command": "pml.prints.commentLine",
        "title": "Comment Current $P Print",
        "category": "PML Prints",
        "icon": "$(comment)"
      },
      {
        "command": "pml.prints.deleteLine",
        "title": "Delete Current $P Print",
        "category": "PML Prints",
        "icon": "$(trash)"
      },
      {
        "command": "pml.alignPML",
        "title": "Align PML",
        "category": "PML Tools"
      },
      {
        "command": "pml.showStringMethods",
        "title": "Show STRING Methods",
        "category": "PML Tools"
      },
      {
        "command": "pml.showRealMethods",
        "title": "Show REAL Methods",
        "category": "PML Tools"
      },
      {
        "command": "pml.showArrayMethods",
        "title": "Show ARRAY Methods",
        "category": "PML Tools"
      },
      {
        "command": "pml.showDbrefMethods",
        "title": "Show DBREF Methods",
        "category": "PML Tools"
      },
      {
        "command": "pml.showAllMethods",
        "title": "Show All Methods",
        "category": "PML Tools"
      },
      {
        "command": "pml.reloadForm",
        "title": "Reload Form",
        "category": "PML Forms",
        "icon": "$(refresh)"
      },
      {
        "command": "pml.generateMethodsSummary",
        "title": "Generate Methods Summary",
        "category": "PML Forms",
        "icon": "$(list-tree)"
      },
      {
        "command": "pml.updateMethodsSummary",
        "title": "Update Methods Summary",
        "category": "PML Forms",
        "icon": "$(sync)"
      },
      {
        "command": "pml.insertMethodDocBlock",
        "title": "Insert Method Documentation Block",
        "category": "PML Forms",
        "icon": "$(note)"
      },
      {
        "command": "pml.makeListBasic",
        "title": "Basic Array",
        "category": "PML Array",
        "icon": "$(symbol-array)"
      },
      {
        "command": "pml.makeListPath",
        "title": "Make Array (add /)",
        "category": "PML Array",
        "icon": "$(file-symlink-directory)"
      },
      {
        "command": "pml.makeListString",
        "title": "Make Array (add |....|)",
        "category": "PML Array",
        "icon": "$(quote)"
      },
      {
        "command": "pml.makeListPathString",
        "title": "Make Array (add / and |....|)",
        "category": "PML Array",
        "icon": "$(symbol-string)"
      },
      {
        "command": "pml.reindexArray",
        "title": "Reindex Selected Array",
        "category": "PML Array",
        "icon": "$(list-ordered)"
      },
      {
        "command": "pml.addToArray",
        "title": "Add to Array",
        "category": "PML Array",
        "icon": "$(add)"
      },
      {
        "command": "pml.openButtonExample",
        "title": "Button Gadgets",
        "category": "PML Examples",
        "icon": "$(circle-large-outline)"
      },
      {
        "command": "pml.openFrameExample",
        "title": "Frame Gadgets",
        "category": "PML Examples",
        "icon": "$(window)"
      }
    ],
    "submenus": [
      {
        "id": "pml.tools",
        "label": "PML Tools",
        "icon": "$(target)"
      },
      {
        "id": "pml.forms",
        "label": "PML - Forms",
        "icon": "$(file-code)"
      },
      {
        "id": "pml.array",
        "label": "PML - Array",
        "icon": "$(symbol-array)"
      },
      {
        "id": "pml.examples",
        "label": "PML - Examples, FAQ",
        "icon": "$(book)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "PML Configuration",
      "properties": {
        "pml.formatter.indentSize": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces for indentation"
        },
        "pml.formatter.removeMultipleEmptyLines": {
          "type": "boolean",
          "default": true,
          "description": "Remove multiple consecutive empty lines"
        },
        "pml.formatter.formatMethodBlocks": {
          "type": "boolean",
          "default": true,
          "description": "Auto-format method blocks"
        },
        "pml.formatter.formatFormBlocks": {
          "type": "boolean",
          "default": true,
          "description": "Auto-format form/frame blocks"
        },
        "pml.formatter.alignAssignments": {
          "type": "boolean",
          "default": true,
          "description": "Align assignment operators (=) in consecutive lines"
        },
        "pml.formatter.fixIndentation": {
          "type": "boolean",
          "default": true,
          "description": "Auto-fix basic indentation (tabs to spaces, correct nesting)"
        },
        "pml.trace": {
          "description": "Enable trace logging for PML extension (completion, etc.).",
          "default": "off",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ]
        },
        "pml.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show reference counts above PML methods and global functions."
        },
        "pml.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show low-noise inline type and parameter hints for PML code."
        },
        "pml.inlayHints.variableTypes": {
          "type": "boolean",
          "default": true,
          "description": "Show types inferred from the first reliable variable assignment in each scope."
        },
        "pml.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter names for unambiguous indexed method and global-function calls."
        },
        "pml.agentKit.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable VS Code integration with e3d-pml-agent-kit."
        },
        "pml.agentKit.path": {
          "type": "string",
          "scope": "machine-overridable",
          "default": "",
          "description": "Path to the e3d-pml-agent-kit repository used for PML review commands. Leave empty to auto-discover a sibling e3d-pml-agent-kit folder in trusted workspaces."
        },
        "pml.agentKit.showRawReport": {
          "type": "boolean",
          "default": false,
          "description": "Show the raw Agent Kit JSON report in the PML Agent Kit output channel."
        },
        "pml.diagnostics.typoDetection": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "warning"
          ],
          "description": "Opt-in keyword typo suggestions based on parser errors. Default is off to avoid diagnostic noise."
        },
        "pml.diagnostics.typeChecking": {
          "type": "string",
          "default": "error",
          "enum": [
            "off",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Disable type checking",
            "Show type errors as warnings",
            "Show type errors as errors"
          ],
          "description": "Type checking diagnostics severity"
        },
        "pml.diagnostics.unusedVariables": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "warning"
          ],
          "enumDescriptions": [
            "Don't check for unused variables",
            "Warn about unused variables"
          ],
          "description": "Unused variables diagnostics severity"
        },
        "pml.diagnostics.arrayIndexZero": {
          "type": "string",
          "default": "error",
          "enum": [
            "off",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Don't check array indices",
            "Warn about zero-based array indices",
            "Error on zero-based array indices"
          ],
          "description": "Array index checking (PML arrays are 1-based)"
        },
        "pml.diagnostics.formErrors": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Suppress parser diagnostics for .pmlfrm files while form DSL support is incomplete",
            "Show .pmlfrm parser diagnostics as warnings",
            "Show .pmlfrm parser diagnostics as errors"
          ],
          "description": "Parser diagnostics for .pmlfrm files"
        },
        "pml.diagnostics.formReferences": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Don't validate .pmlfrm callback and gadget references",
            "Show missing .pmlfrm callback and gadget references as warnings",
            "Show missing .pmlfrm callback and gadget references as errors"
          ],
          "description": "Callback and gadget reference validation for .pmlfrm files"
        },
        "pml.indexing.exclude": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/out/**",
            "**/docs/**",
            "**/scripts/**",
            "**/.git/**",
            "**/.vscode/**",
            "**/examples/**",
            "**/hide_examples/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns for files to exclude from workspace indexing"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "pml.quickActions.open",
          "when": "editorLangId == pml",
          "group": "1_pml@0"
        },
        {
          "command": "pml.agentKit.reviewCurrentFile",
          "when": "editorLangId == pml",
          "group": "1_pml@1"
        },
        {
          "submenu": "pml.array",
          "when": "editorLangId == pml && editorHasSelection",
          "group": "1_pml@2"
        },
        {
          "submenu": "pml.forms",
          "when": "editorLangId == pml",
          "group": "1_pml@3"
        },
        {
          "submenu": "pml.examples",
          "when": "editorLangId == pml",
          "group": "1_pml@4"
        }
      ],
      "pml.tools": [
        {
          "command": "pml.sortLinesAsc",
          "group": "1_sort@1"
        },
        {
          "command": "pml.sortLinesDesc",
          "group": "1_sort@2"
        },
        {
          "command": "pml.sortLinesLength",
          "group": "1_sort@3"
        },
        {
          "command": "pml.sortLinesSmart",
          "group": "1_sort@4"
        },
        {
          "command": "pml.removeDuplicates",
          "group": "2_duplicates@1"
        },
        {
          "command": "pml.removeConsecutiveDuplicates",
          "group": "2_duplicates@2"
        },
        {
          "command": "pml.removeEmptyLines",
          "group": "3_whitespace@1"
        },
        {
          "command": "pml.removeWhitespaceLines",
          "group": "3_whitespace@2"
        },
        {
          "command": "pml.trimWhitespace",
          "group": "3_whitespace@3"
        },
        {
          "command": "pml.tabsToSpaces",
          "group": "3_whitespace@4"
        },
        {
          "command": "pml.spacesToTabs",
          "group": "3_whitespace@5"
        },
        {
          "command": "pml.extractVariables",
          "group": "4_extract@1"
        },
        {
          "command": "pml.extractMethods",
          "group": "4_extract@2"
        },
        {
          "command": "pml.alignPML",
          "group": "5_align@1"
        },
        {
          "command": "pml.addComments",
          "group": "6_comments@1"
        },
        {
          "command": "pml.removeComments",
          "group": "6_comments@2"
        },
        {
          "command": "pml.prints.actions",
          "group": "7_prints@1"
        },
        {
          "command": "pml.prints.next",
          "group": "7_prints@2"
        },
        {
          "command": "pml.prints.previous",
          "group": "7_prints@3"
        },
        {
          "command": "pml.prints.commentAll",
          "group": "7_prints@4"
        },
        {
          "command": "pml.prints.uncommentAll",
          "group": "7_prints@5"
        },
        {
          "command": "pml.prints.deleteAll",
          "group": "7_prints@6"
        },
        {
          "submenu": "pml.forms",
          "group": "7_forms"
        },
        {
          "submenu": "pml.array",
          "group": "8_array"
        },
        {
          "submenu": "pml.examples",
          "group": "9_examples"
        }
      ],
      "pml.forms": [
        {
          "command": "pml.reloadForm",
          "group": "1_forms@1"
        },
        {
          "command": "pml.insertMethodDocBlock",
          "group": "1_forms@2"
        },
        {
          "command": "pml.generateMethodsSummary",
          "group": "1_forms@3"
        },
        {
          "command": "pml.updateMethodsSummary",
          "group": "1_forms@4"
        }
      ],
      "pml.array": [
        {
          "command": "pml.makeListBasic",
          "group": "1_array@1"
        },
        {
          "command": "pml.makeListPath",
          "group": "1_array@2"
        },
        {
          "command": "pml.makeListString",
          "group": "1_array@3"
        },
        {
          "command": "pml.makeListPathString",
          "group": "1_array@4"
        },
        {
          "command": "pml.reindexArray",
          "group": "2_reindex@1"
        },
        {
          "command": "pml.addToArray",
          "group": "3_add@1"
        }
      ],
      "pml.examples": [
        {
          "command": "pml.openButtonExample",
          "group": "1_examples@1"
        },
        {
          "command": "pml.openFrameExample",
          "group": "1_examples@2"
        }
      ],
      "editor/title": [
        {
          "command": "pml.formatDocument",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'",
          "group": "navigation"
        },
        {
          "submenu": "pml.tools",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "pml.prints.clear",
          "when": "false"
        },
        {
          "command": "pml.quickActions.open",
          "when": "editorLangId == pml"
        },
        {
          "command": "pml.toggleVariableTypeHints",
          "when": "editorLangId == pml"
        },
        {
          "command": "pml.sortMethodsAscending",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'"
        },
        {
          "command": "pml.sortMethodsDescending",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'"
        },
        {
          "command": "pml.sortLinesAsc",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'"
        },
        {
          "command": "pml.sortLinesDesc",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'"
        },
        {
          "command": "pml.sortLinesLength",
          "when": "resourceExtname == '.pml' || resourceExtname == '.pmlobj' || resourceExtname == '.pmlfnc' || resourceExtname == '.pmlfrm' || resourceExtname == '.pmlmac' || resourceExtname == '.pmlcmd'"
        },
